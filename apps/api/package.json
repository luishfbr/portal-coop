{
  "name": "@portal-coop/api",
  "version": "1.0.50",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch src/index.ts",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:seed": "bun run ./src/db/seed.ts",
    "auth:generate": "bunx --bun auth@latest generate --output ./src/db/schema/auth-schema.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@types/nodemailer": "^8.0.0",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "elysia": "^1.4.28",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@portal-coop/eslint-config": "workspace:*",
    "@portal-coop/typescript-config": "workspace:*",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0"
  },
  "module": "src/index.js"
}